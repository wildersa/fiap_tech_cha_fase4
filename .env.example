# =========================================================================
# Tech Challenge Fase 4 - Configurações de Caminhos (.env)
# =========================================================================

# Modo de instalação:
# true  = dev/train: habilita treino, MLflow e sincroniza automaticamente o melhor modelo para MODEL_DIR.
# false = somente inferência: não consulta MLflow; usa apenas os artefatos empacotados/apontados abaixo.
ENABLE_TRAINING_API=false

# Diretórios onde os modelos (model.onnx, preprocessor.joblib, metrics.json, etc.) serão carregados.
# Em dev/train, estes diretórios recebem o melhor modelo sincronizado do MLflow.
# Em somente inferência, a API usa exatamente estes diretórios, sem promoção automática.
MODEL_DIR=models/lstm_petr4
MODEL_DIR_MULTI=models/lstm_petr4_multi

# Caminho opcional para a base de dados local em formato CSV
# Deixe em branco para baixar os dados dinamicamente do Yahoo Finance (yfinance)
DATA_CSV_PATH=

# Diretório dedicado para logs e rastreamento do MLflow
MLFLOW_TRACKING_URI=mlruns
