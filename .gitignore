# Project specific - Model artifacts
# Git deve manter APENAS os artefatos dos modelos campeões (lstm_petr4 e lstm_petr4_multi).
# Outros modelos treinados dinamicamente no container DEVEM ser ignorados.
models/*
!models/.gitkeep

# Libera APENAS as pastas dos modelos campeões oficiais
!models/lstm_petr4/
!models/lstm_petr4_multi/

# Libera os artefatos essenciais de inferência apenas dentro das pastas permitidas acima
!models/lstm_petr4/*.onnx
!models/lstm_petr4/*.joblib
!models/lstm_petr4/*.json
!models/lstm_petr4/*.png
!models/lstm_petr4/*.csv

!models/lstm_petr4_multi/*.onnx
!models/lstm_petr4_multi/*.joblib
!models/lstm_petr4_multi/*.json
!models/lstm_petr4_multi/*.png
!models/lstm_petr4_multi/*.csv

# Ignora explicitamente pesos do PyTorch dentro das pastas permitidas
models/lstm_petr4/*.pt
models/lstm_petr4/*.safetensors
models/lstm_petr4/*.pth
models/lstm_petr4_multi/*.pt
models/lstm_petr4_multi/*.safetensors
models/lstm_petr4_multi/*.pth

