{
  "builds": [
    {
      "src": "src/api.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/api.py"
    }
  ],
  "functions": {
    "src/api.py": {
      "includeFiles": "{models/**/*.{onnx,onnx.data,joblib,json,png},src/**}"
    }
  }
}
